{
  "name": "nayduk/nayduk",
  "description": "Найдук — премиальная платформа объявлений и аукционов",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.5",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "ext-redis": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "ext-openssl": "*",
    "ext-filter": "*",
    
    "slim/slim": "^4.12",
    "slim/psr7": "^1.7",
    "slim/csrf": "^1.3",
    
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    
    "phpmailer/phpmailer": "^6.9",
    "endroid/qr-code": "^5.0",
    
    "predis/predis": "^2.2",
    "resque/php-resque": "^2.1",
    
    "league/plates": "^4.1",
    "twig/twig": "^3.10",
    
    "monolog/monolog": "^3.7",
    "symfony/var-dumper": "^7.1",
    
    "league/oauth2-client": "^2.7",
    "hybridauth/hybridauth": "^3.11"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.59",
    "symfony/var-dumper": "^7.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "App\\Http\\": "app/Http/",
      "App\\Http\\Controllers\\": "app/Http/Controllers/",
      "App\\Http\\Middleware\\": "app/Http/Middleware/",
      "App\\Models\\": "app/Models/",
      "App\\Services\\": "app/Services/",
      "App\\Jobs\\": "app/Jobs/",
      "App\\Providers\\": "app/Providers/"
    },
    "files": [
      "includes/helpers.php",
      "includes/constants.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\""
    ],
    "post-autoload-dump": [
      "@php -r \"file_exists('bootstrap/cache') || mkdir('bootstrap/cache', 0755, true);\""
    ],
    "test": "phpunit --colors=always",
    "analyse": "phpstan analyse --memory-limit=1G --no-progress",
    "fix": "php-cs-fixer fix --config=.php-cs-fixer.php --verbose",
    "optimize": [
      "@composer dump-autoload --optimize --classmap-authoritative",
      "@php scripts/warmup_opcache.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "php-http/discovery": true
    },
    "platform": {
      "php": "8.5.4"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}